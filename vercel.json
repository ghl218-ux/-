{
  "functions": {
    "api/generate.py": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/combined.py": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/public/$1" }
  ]
}
